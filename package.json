{
  "name": "fulltab-search",
  "displayName": "FullTab Search",
  "description": "Full-tab project search with tabs, filters, and inline results",
  "version": "0.0.1",
  "publisher": "local",
  "repository": {
    "type": "git",
    "url": "https://github.com/benjih/vscode-fulltab-search.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:fullTabSearch.open"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "fullTabSearch.open",
        "title": "FullTab Search: Open Project Search",
        "icon": "$(search)"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "tsc --noEmit -p ./",
    "test": "node ./out/test/runTest.js",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.45",
    "@vscode/ripgrep": "^1.15.14"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^3.9.2",
    "glob": "^10.4.0",
    "mocha": "^10.7.0",
    "typescript": "6.0.3"
  }
}
