{
  "name": "fulltab-search",
  "displayName": "FullTab Search",
  "description": "Full-tab project search with tabs, filters, and inline results",
  "version": "0.0.1",
  "publisher": "local",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:fullTabSearch.open"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "fullTabSearch.open",
        "title": "FullTab Search: Open Project Search",
        "icon": "$(search)"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "tsc --noEmit -p ./",
    "test": "node ./out/test/runTest.js"
  },
  "dependencies": {
    "@vscode/ripgrep": "^1.15.14"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.4.0",
    "glob": "^10.4.0",
    "mocha": "^10.7.0",
    "typescript": "^5.5.0"
  }
}
